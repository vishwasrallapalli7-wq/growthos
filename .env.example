# GrowthOS API Configuration
PORT=3001

# Email — use Resend (recommended) OR SMTP
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=GrowthOS <onboarding@yourdomain.com>

# SMTP alternative
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false

# Instagram Graph API (Meta Business)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# ElevenLabs — multilingual voice-over (sounds human, not robotic)
ELEVENLABS_API_KEY=your_elevenlabs_key

# OpenAI — AI design generation (DALL-E 3) + website audits
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Meta OAuth — real Instagram connection
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3001/api/oauth/instagram/callback

# FFmpeg (install separately) — merges voice-over into videos
